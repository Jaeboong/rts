# Phase 40-B Nanoclaw bridge — see docs/AI_INFRASTRUCTURE_NANOCLAW.md §5.
# Copy to .env (which is gitignored) and fill in. Read by vite.config.ts at
# request time (server-side only — never exposed to the client because we do
# NOT use the VITE_ prefix). Plugin is `apply: 'serve'` so it never ships in
# production builds.

# Nanoclaw HTTP host (no trailing slash). The bridge POSTs to ${NANOCLAW_URL}/api/agent-message.
NANOCLAW_URL=http://localhost:4500

# Bearer token for the Nanoclaw HTTP endpoint. Optional — the bridge omits the
# Authorization header when unset, useful for a token-less local Nanoclaw dev run.
NANOCLAW_TOKEN=

# Switch enemy AI from ScriptedAI to NanoclawPlayer. VITE_ prefix because it's
# inlined into the client bundle at build time (see main.ts buildEnemyPlayer).
# Default unset = ScriptedAI Tier 3 (deterministic offline). Set to "1" to
# route enemy commands through the Nanoclaw bridge.
VITE_USE_NANOCLAW=

# Phase 42 OpenClaw bridge — see docs/DESIGN.md §10 Phase 42.
# OpenClaw HTTP gateway base URL (no trailing slash). The bridge POSTs to
# ${OPENCLAW_URL}/v1/chat/completions with the OpenAI Chat Completions wire
# format. Default local port for `openclaw gateway start` is 18789.
OPENCLAW_URL=http://localhost:18789

# Bearer token for the OpenClaw HTTP endpoint. Read from `openclaw gateway start`
# output and put the real value in `.env` (gitignored), NOT here. Bridge omits
# Authorization header when unset, useful for token-less local dev runs.
OPENCLAW_GATEWAY_TOKEN=

# Phase 42 runtime AI selector — initial enemy player at startup. Values:
#   none     = NoOpPlayer (no enemy AI active until user clicks a HUD button) — DEFAULT
#   claude   = NanoclawPlayer (Anthropic via Nanoclaw bridge)
#   codex    = OpenClawPlayer (Codex via OpenClaw gateway)
#   scripted = ScriptedAI Tier 3 (deterministic offline)
# Unset OR 'none' = lazy startup: enemy team idles until the user picks an AI
# from the HUD. Runtime swap via the buttons works regardless of this setting.
VITE_DEFAULT_ENEMY=none

# Phase 42 — model id sent in the OpenClaw chat-completions body. The gateway
# resolves it to the agent (which carries the AGENTS.md system prompt) AND the
# underlying provider (e.g. openai-codex/gpt-5.5). Default 'openclaw/default'.
VITE_OPENCLAW_AGENT_ID=openclaw/default
