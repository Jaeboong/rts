# Phase 40-B Nanoclaw bridge — see docs/AI_INFRASTRUCTURE_NANOCLAW.md §5.
# Copy to .env (which is gitignored) and fill in. Read by vite.config.ts at
# request time (server-side only — never exposed to the client because we do
# NOT use the VITE_ prefix). Plugin is `apply: 'serve'` so it never ships in
# production builds.

# Nanoclaw HTTP host (no trailing slash). The bridge POSTs to ${NANOCLAW_URL}/api/agent-message.
NANOCLAW_URL=http://localhost:4500

# Bearer token for the Nanoclaw HTTP endpoint. Optional — the bridge omits the
# Authorization header when unset, useful for a token-less local Nanoclaw dev run.
NANOCLAW_TOKEN=
